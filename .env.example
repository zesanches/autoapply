# App
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://autoapply:autoapply@localhost:5432/autoapply

# Redis
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=<gerar: openssl rand -hex 32>

# Encryption (para API keys dos usuários)
ENCRYPTION_KEY=<gerar: openssl rand -hex 32>

# CORS
CORS_ORIGIN=http://localhost:3000

# Anthropic (opcional no MVP local — Claude Code SDK usado por padrão)
ANTHROPIC_API_KEY=

# Sentry (opcional)
SENTRY_DSN=

# Worker
MAX_BROWSER_INSTANCES=3
